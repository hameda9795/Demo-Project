<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="sandBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#A67B5B"/>
      <stop offset="100%" style="stop-color:#8B5A2B"/>
    </linearGradient>
    <pattern id="sanding" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse">
      <circle cx="25" cy="25" r="1" fill="#3E2723" opacity="0.1"/>
    </pattern>
  </defs>
  <rect width="1200" height="800" fill="url(#sandBg)"/>
  <rect width="1200" height="800" fill="url(#sanding)"/>
  <text x="600" y="400" font-family="serif" font-size="48" fill="#3E2723" text-anchor="middle" opacity="0.5">Schuren</text>
</svg>
