<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="oak" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#A67B5B"/>
      <stop offset="100%" style="stop-color:#8B5A2B"/>
    </linearGradient>
    <pattern id="oakGrain" x="0" y="0" width="200" height="30" patternUnits="userSpaceOnUse">
      <path d="M0,15 Q100,5 200,15" stroke="#6B4423" stroke-width="1" fill="none" opacity="0.4"/>
      <path d="M0,20 Q100,25 200,20" stroke="#6B4423" stroke-width="0.5" fill="none" opacity="0.3"/>
    </pattern>
  </defs>
  <rect width="800" height="600" fill="url(#oak)"/>
  <rect width="800" height="600" fill="url(#oakGrain)"/>
  <text x="400" y="300" font-family="serif" font-size="36" fill="#3E2723" text-anchor="middle" opacity="0.6">Eiken</text>
</svg>
