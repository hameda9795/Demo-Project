<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="macroBg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#C4A77D"/>
      <stop offset="100%" style="stop-color:#A67B5B"/>
    </linearGradient>
    <pattern id="macroGrain" x="0" y="0" width="300" height="100" patternUnits="userSpaceOnUse">
      <path d="M0,50 Q150,20 300,50 Q150,80 0,50" stroke="#8B5A2B" stroke-width="2" fill="none" opacity="0.4"/>
      <path d="M0,70 Q150,90 300,70" stroke="#6B4423" stroke-width="1" fill="none" opacity="0.3"/>
    </pattern>
  </defs>
  <rect width="1200" height="800" fill="url(#macroBg)"/>
  <rect width="1200" height="800" fill="url(#macroGrain)"/>
  <text x="600" y="400" font-family="serif" font-size="48" fill="#3E2723" text-anchor="middle" opacity="0.4">Houtnerf</text>
</svg>
