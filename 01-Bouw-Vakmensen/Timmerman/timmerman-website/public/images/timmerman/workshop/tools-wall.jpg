<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="toolsBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4A5568"/>
      <stop offset="100%" style="stop-color:#2D3748"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="800" fill="url(#toolsBg)"/>
  <!-- Tool silhouettes -->
  <rect x="100" y="100" width="80" height="300" rx="5" fill="#718096" opacity="0.3"/>
  <rect x="200" y="150" width="60" height="250" rx="5" fill="#718096" opacity="0.3"/>
  <rect x="300" y="80" width="100" height="350" rx="5" fill="#718096" opacity="0.3"/>
  <rect x="450" y="120" width="70" height="280" rx="5" fill="#718096" opacity="0.3"/>
  <rect x="550" y="90" width="90" height="320" rx="5" fill="#718096" opacity="0.3"/>
  <text x="600" y="550" font-family="serif" font-size="48" fill="#D4AF37" text-anchor="middle" opacity="0.5">Gereedschap</text>
</svg>
