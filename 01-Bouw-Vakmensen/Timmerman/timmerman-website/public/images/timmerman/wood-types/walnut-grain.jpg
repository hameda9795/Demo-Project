<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="walnut" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#5D4037"/>
      <stop offset="100%" style="stop-color:#3E2723"/>
    </linearGradient>
    <pattern id="walnutGrain" x="0" y="0" width="150" height="40" patternUnits="userSpaceOnUse">
      <path d="M0,20 Q75,10 150,20" stroke="#8B5A2B" stroke-width="1.5" fill="none" opacity="0.3"/>
      <path d="M0,30 Q75,35 150,30" stroke="#A67B5B" stroke-width="0.5" fill="none" opacity="0.2"/>
    </pattern>
  </defs>
  <rect width="800" height="600" fill="url(#walnut)"/>
  <rect width="800" height="600" fill="url(#walnutGrain)"/>
  <text x="400" y="300" font-family="serif" font-size="36" fill="#D4AF37" text-anchor="middle" opacity="0.6">Walnoot</text>
</svg>
